DISCORD_TOKEN=
CLIENT_ID=
GUILD_ID=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# レポートを解決済みとしてマークするために必要な権限 (例: ManageMessages)
# 指定可能な文字列は Discord.js の PermissionsBitField.Flags のキーです。
RESOLVE_PERMISSION=ManageMessages

# AI & Proxmox
GEMINI_API_KEY=
# Proxmoxノード設定 (JSON形式)
# 例: [{"name":"pve1","host":"192.168.1.10","user":"root","password":"yourpassword"},{"name":"pve2","host":"192.168.1.11","user":"root","sshKey":"/path/to/id_rsa"}]
PROXMOX_NODES='[{"name":"pve1","host":"192.168.5.201","user":"root","password":"vn101oyk"},{"name":"pve2","host":"192.168.5.202","user":"root","password":"vn101OYK"}]'
# AIが反応するチャンネルID (カンマ区切り)
AI_CHANNELS=
